{
  "version": 8,
  "name": "Hybrid",
  "glyphs": "https://vector.openstreetmap.org/demo/shortbread/fonts/{fontstack}/{range}.pbf",
  "sprite": [
    {
      "id": "basics",
      "url": "https://vector.openstreetmap.org/demo/shortbread/sprites/basics/sprites"
    }
  ],
  "sources": {
    "esri-world-imagery": {
      "type": "raster",
      "tiles": [
        "https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}"
      ],
      "tileSize": 256,
      "attribution": "Tiles &copy; Esri &mdash; Source: Esri, Maxar, Earthstar Geographics, and the GIS User Community",
      "maxzoom": 19
    },
    "versatiles-shortbread": {
      "type": "vector",
      "tiles": [
        "https://vector.openstreetmap.org/shortbread_v1/{z}/{x}/{y}.mvt"
      ],
      "scheme": "xyz",
      "bounds": [-180, -85.0511287798066, 180, 85.0511287798066],
      "minzoom": 0,
      "maxzoom": 14,
      "attribution": "&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors"
    }
  },
  "layers": [
    {
      "id": "satellite-base",
      "type": "raster",
      "source": "esri-world-imagery",
      "minzoom": 0,
      "maxzoom": 22
    },
    {
      "id": "path-casing",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 14,
      "filter": [
        "in",
        "kind",
        "path",
        "track",
        "pedestrian",
        "footway",
        "cycleway",
        "steps"
      ],
      "paint": {
        "line-color": "rgba(0,0,0,0.55)",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          14,
          1.4,
          18,
          3.5,
          22,
          6
        ]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "path-fill",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 14,
      "filter": [
        "in",
        "kind",
        "path",
        "track",
        "pedestrian",
        "footway",
        "cycleway",
        "steps"
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          14,
          0.6,
          18,
          2,
          22,
          4
        ],
        "line-dasharray": [1.5, 1.5]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "street-minor-casing",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 12,
      "filter": [
        "in",
        "kind",
        "service",
        "residential",
        "living_street",
        "unclassified"
      ],
      "paint": {
        "line-color": "rgba(0,0,0,0.6)",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.8,
          16,
          3.5,
          20,
          8
        ]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "street-minor-fill",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 12,
      "filter": [
        "in",
        "kind",
        "service",
        "residential",
        "living_street",
        "unclassified"
      ],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.3,
          16,
          2.2,
          20,
          6
        ]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "street-major-casing",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 8,
      "filter": [
        "in",
        "kind",
        "tertiary",
        "tertiary_link",
        "secondary",
        "secondary_link",
        "primary",
        "primary_link",
        "trunk",
        "trunk_link",
        "motorway",
        "motorway_link"
      ],
      "paint": {
        "line-color": "rgba(0,0,0,0.65)",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1, 14, 4, 20, 14]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "street-major-fill",
      "type": "line",
      "source": "versatiles-shortbread",
      "source-layer": "streets",
      "minzoom": 8,
      "filter": [
        "in",
        "kind",
        "tertiary",
        "tertiary_link",
        "secondary",
        "secondary_link",
        "primary",
        "primary_link",
        "trunk",
        "trunk_link",
        "motorway",
        "motorway_link"
      ],
      "paint": {
        "line-color": "#ffe082",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.5,
          14,
          3,
          20,
          11
        ]
      },
      "layout": { "line-cap": "round", "line-join": "round" }
    },
    {
      "id": "street-labels",
      "type": "symbol",
      "source": "versatiles-shortbread",
      "source-layer": "street_labels",
      "minzoom": 13,
      "layout": {
        "symbol-placement": "line",
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 10, 18, 13],
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#ffffff",
        "text-halo-color": "rgba(0,0,0,0.85)",
        "text-halo-width": 1.4
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "versatiles-shortbread",
      "source-layer": "place_labels",
      "minzoom": 4,
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          10,
          12,
          14,
          16,
          16
        ],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#ffffff",
        "text-halo-color": "rgba(0,0,0,0.85)",
        "text-halo-width": 1.5
      }
    }
  ]
}
